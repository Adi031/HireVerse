# Database Configuration
# Copy this file to application-dev.properties and fill in your local details
spring.datasource.url=jdbc:mysql://localhost:3306/job_portal_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
spring.datasource.username=root
spring.datasource.password=YOUR_MYSQL_PASSWORD_HERE

# JWT Configuration
# Use a strong secret key (at least 256-bit)
jwt.secret=YOUR_SECRET_KEY_HERE
jwt.expiration=86400000
